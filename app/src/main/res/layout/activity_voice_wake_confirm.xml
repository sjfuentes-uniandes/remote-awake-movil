<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/successBarContainer"
        app:layout_constraintVertical_bias="0.3">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:lineSpacingMultiplier="1.1"
            android:text="Confirmando\nDespertar..."
            android:textAlignment="center"
            android:textColor="@color/primary"
            android:textSize="48sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="40dp"
            android:padding="24dp"
            android:background="@null"
            android:src="@drawable/ic_mic"
            android:contentDescription="Micrófono"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/tvInstructionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="Repita:"
            android:fontFamily="sans-serif"
            android:textColor="@color/tertiary"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvPhrase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="\u201cYa me desperté\npor completo\u201d"
            android:textAlignment="center"
            android:fontFamily="sans-serif"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:textSize="42sp"
            android:lineSpacingMultiplier="1.2" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/successBarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_success_bar"
        android:paddingHorizontal="24dp"
        android:paddingVertical="24dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvSuccessMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mensaje recibido!"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:fontFamily="sans-serif" />

        <ImageView
            android:id="@+id/ivClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="4dp"
            android:src="@drawable/ic_close"
            android:contentDescription="Cerrar"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
