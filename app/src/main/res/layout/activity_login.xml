<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="72dp"
        android:text="Acceso"
        android:textColor="@color/primary"
        android:textSize="57sp"
        android:fontFamily="sans-serif"
        android:fontWeight="400"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvCorreoLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="54dp"
        android:layout_marginTop="88dp"
        android:layout_marginEnd="54dp"
        android:text="Correo"
        android:textColor="@color/primary"
        android:textSize="32sp"
        android:fontFamily="sans-serif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <EditText
        android:id="@+id/etCorreo"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="54dp"
        android:background="@drawable/bg_login_input"
        android:gravity="center_vertical"
        android:hint="correo"
        android:inputType="textEmailAddress"
        android:paddingStart="14dp"
        android:paddingEnd="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvCorreoLabel"
        app:layout_constraintTop_toBottomOf="@id/tvCorreoLabel" />

    <TextView
        android:id="@+id/tvPasswordLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="82dp"
        android:text="Contraseña"
        android:textColor="@color/primary"
        android:textSize="32sp"
        android:fontFamily="sans-serif"
        app:layout_constraintEnd_toEndOf="@id/etCorreo"
        app:layout_constraintStart_toStartOf="@id/etCorreo"
        app:layout_constraintTop_toBottomOf="@id/etCorreo" />

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_login_input"
        android:gravity="center_vertical"
        android:hint="contraseña"
        android:inputType="textPassword"
        android:paddingStart="14dp"
        android:paddingEnd="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:textSize="16sp"
        app:layout_constraintEnd_toStartOf="@id/ivPasswordToggle"
        app:layout_constraintStart_toStartOf="@id/tvPasswordLabel"
        app:layout_constraintTop_toBottomOf="@id/tvPasswordLabel" />

    <ImageView
        android:id="@+id/ivPasswordToggle"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="54dp"
        android:src="@drawable/ic_visibility_off"
        android:contentDescription="Mostrar u ocultar contraseña"
        app:layout_constraintBottom_toBottomOf="@id/etPassword"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/etPassword" />

    <TextView
        android:id="@+id/tvForgotPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="¿Olvidaste tu contraseña?"
        android:textColor="@color/error"
        android:textSize="12sp"
        android:fontFamily="sans-serif"
        app:layout_constraintStart_toStartOf="@id/etPassword"
        app:layout_constraintTop_toBottomOf="@id/etPassword" />

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="192dp"
        android:layout_height="96dp"
        android:layout_marginTop="100dp"
        android:background="@drawable/bg_login_button"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="Acceder"
        android:textAllCaps="false"
        android:textColor="@color/onPrimary"
        android:textSize="24sp"
        android:fontFamily="sans-serif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.483"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvForgotPassword" />

</androidx.constraintlayout.widget.ConstraintLayout>
