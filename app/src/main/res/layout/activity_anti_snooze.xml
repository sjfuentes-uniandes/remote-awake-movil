<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="63dp"
        android:fontFamily="sans-serif"
        android:text="Hora de\ndespertar!!"
        android:textAlignment="center"
        android:textColor="@color/primary"
        android:textSize="57sp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="165dp"
        android:layout_height="165dp"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="60dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <ImageView
            android:layout_width="165dp"
            android:layout_height="165dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_alarm"
            app:tint="#000000" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:text="Alarma Anti Snooze"
        android:textColor="@color/tertiary"
        android:textSize="16sp" />

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="280dp"
        android:layout_height="2dp"
        android:layout_marginTop="17dp"
        app:dividerColor="@color/secondaryContainer" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="47dp"
        android:text="5:00 AM"
        android:textColor="@color/text_primary"
        android:textSize="57sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="Resolver para\ndesactivar"
        android:textAlignment="center"
        android:textColor="@color/instruction_accent"
        android:textSize="20sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12+6 ="
            android:textColor="@color/text_primary"
            android:textSize="24sp" />

        <EditText
            android:id="@+id/etMathAnswer"
            android:layout_width="80dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_math_input"
            android:gravity="center"
            android:hint="?"
            android:inputType="number"
            android:maxLength="4"
            android:paddingHorizontal="12dp"
            tools:ignore="Autofill" />
    </LinearLayout>

</LinearLayout>
